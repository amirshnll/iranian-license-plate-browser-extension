{
    "manifest_version": 3,
    "name": "Iranian License Plate Finder",
    "version": "1.1.0",
    "description": "A tool to identify the city and province of Iranian vehicle license plates",
    "icons": {
        "16": "src/icons/icon16.png",
        "24": "src/icons/icon24.png",
        "32": "src/icons/icon32.png",
        "64": "src/icons/icon64.png",
        "128": "src/icons/icon128.png",
        "256": "src/icons/icon256.png",
        "512": "src/icons/icon512.png"
    },
    "permissions": [],
    "action": {
        "default_icon": "src/icons/icon128.png",
        "default_popup": "src/popup.html",
        "default_title": "iranian-license-plate-finder"
    },
    "browser_specific_settings": {
        "gecko": {
            "id": "iranian-license-plate-finder@ashokri.com",
            "strict_min_version": "142.0",
            "data_collection_permissions": {
                "required": [
                    "none"
                ]
            }
        }
    }
}